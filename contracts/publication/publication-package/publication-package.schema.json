{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/contracts/ct-pub-001.schema.json",
  "title": "Publication Package Contract",
  "type": "object",
  "required": [
    "contract",
    "package_id",
    "request_id",
    "approved_draft_id",
    "approved_draft_version",
    "publish_decision",
    "article_content",
    "seo_metadata",
    "output_format",
    "generated_at"
  ],
  "properties": {
    "contract": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/contractRef"
    },
    "package_id": {
      "type": "string",
      "pattern": "^PKG-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string"
    },
    "approved_draft_id": {
      "type": "string"
    },
    "approved_draft_version": {
      "type": "string"
    },
    "publish_decision": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/publishDecision"
    },
    "article_content": {
      "type": "string",
      "minLength": 1
    },
    "seo_metadata": {
      "type": "object",
      "required": [
        "seo_title",
        "h1"
      ],
      "properties": {
        "seo_title": {
          "type": "string"
        },
        "meta_description": {
          "type": [
            "string",
            "null"
          ]
        },
        "h1": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "output_format": {
      "type": "string"
    },
    "quality_summary": {
      "type": "object"
    },
    "remaining_advisories": {
      "type": "array"
    },
    "before_after": {
      "type": "object"
    },
    "change_summary": {
      "type": "array"
    },
    "generated_at": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/isoDateTime"
    }
  },
  "additionalProperties": false
}