{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/ct-dec-001.schema.json",
  "title": "Decision Context",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "decision_context_id",
    "request_id",
    "request_type",
    "subjects",
    "created_at"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "const": "CT-DEC-001"
        },
        "version": {
          "const": "1.0.0"
        }
      },
      "additionalProperties": false
    },
    "decision_context_id": {
      "type": "string",
      "pattern": "^DCTX-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "request_type": {
      "enum": [
        "new_article",
        "existing_article_improvement",
        "partial_rewrite",
        "seo_refresh",
        "fact_update",
        "structural_improvement",
        "ctr_improvement",
        "content_expansion"
      ]
    },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "subject_id",
          "component",
          "current_state"
        ],
        "properties": {
          "subject_id": {
            "type": "string"
          },
          "component": {
            "type": "string"
          },
          "current_state": {},
          "metrics": {
            "type": "object"
          },
          "quality_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "available_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
