{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/ct-dec-003.schema.json",
  "title": "Decision Action Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract",
    "action_plan_id",
    "request_id",
    "decision_records",
    "actions",
    "decision_gate_status",
    "created_at"
  ],
  "properties": {
    "contract": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "const": "CT-DEC-003"
        },
        "version": {
          "const": "1.0.0"
        }
      },
      "additionalProperties": false
    },
    "action_plan_id": {
      "type": "string",
      "pattern": "^DAP-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string"
    },
    "decision_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "order",
          "component",
          "action"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "component": {
            "type": "string"
          },
          "action": {
            "enum": [
              "preserve",
              "revise",
              "add",
              "remove",
              "verify",
              "separate_article",
              "no_change",
              "manual_review"
            ]
          },
          "reason": {
            "type": "string"
          },
          "pattern_category": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "decision_gate_status": {
      "enum": [
        "pass",
        "pass_with_warning",
        "fail",
        "manual_review_required"
      ]
    },
    "unresolved_conflicts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
