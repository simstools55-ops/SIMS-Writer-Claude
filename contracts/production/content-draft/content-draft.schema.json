{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/contracts/ct-prd-001.schema.json",
  "title": "Content Draft Contract",
  "type": "object",
  "required": [
    "contract",
    "draft_id",
    "request_id",
    "plan_id",
    "draft_version",
    "h1",
    "sections",
    "status"
  ],
  "properties": {
    "contract": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/contractRef"
    },
    "draft_id": {
      "type": "string",
      "pattern": "^DRF-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "draft_version": {
      "type": "string"
    },
    "seo_title": {
      "type": [
        "string",
        "null"
      ]
    },
    "meta_description": {
      "type": [
        "string",
        "null"
      ]
    },
    "h1": {
      "type": "string",
      "minLength": 1
    },
    "introduction": {
      "type": "string"
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "heading",
          "level",
          "body"
        ],
        "properties": {
          "heading": {
            "type": "string"
          },
          "level": {
            "type": "integer",
            "minimum": 2,
            "maximum": 6
          },
          "body": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "faq": {
      "type": "array"
    },
    "conclusion": {
      "type": [
        "string",
        "null"
      ]
    },
    "internal_links": {
      "type": "array"
    },
    "citations": {
      "type": "array"
    },
    "unresolved_items": {
      "type": "array"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_validation",
        "revision_required",
        "approved"
      ]
    }
  },
  "additionalProperties": false
}