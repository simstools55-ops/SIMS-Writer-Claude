{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/contracts/ct-pln-001.schema.json",
  "title": "Content Plan Contract",
  "type": "object",
  "required": [
    "contract",
    "plan_id",
    "request_id",
    "plan_version",
    "primary_intent",
    "main_answer",
    "content_requirements",
    "article_structure",
    "planning_gate_status"
  ],
  "properties": {
    "contract": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/contractRef"
    },
    "plan_id": {
      "type": "string",
      "pattern": "^PLN-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string"
    },
    "plan_version": {
      "type": "string"
    },
    "primary_intent": {
      "type": "string",
      "minLength": 1
    },
    "supporting_intents": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/stringArray"
    },
    "main_answer": {
      "type": "string",
      "minLength": 1
    },
    "reader_model": {
      "type": "object"
    },
    "content_requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "description",
          "priority"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "priority": {
            "type": "string",
            "enum": [
              "must",
              "should",
              "could"
            ]
          },
          "evidence_required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "article_structure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "heading",
          "level",
          "purpose"
        ],
        "properties": {
          "heading": {
            "type": "string"
          },
          "level": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "purpose": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_plan": {
      "type": "array"
    },
    "out_of_scope": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/stringArray"
    },
    "quality_targets": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/stringArray"
    },
    "planning_gate_status": {
      "type": "string",
      "enum": [
        "pass",
        "pass_with_warning",
        "fail",
        "manual_review_required"
      ]
    }
  },
  "additionalProperties": false
}