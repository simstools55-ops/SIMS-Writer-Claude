{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/contracts/ct-knw-001.schema.json",
  "title": "Knowledge Assembly Contract",
  "type": "object",
  "required": [
    "contract",
    "assembly_id",
    "request_id",
    "selected_items",
    "coverage",
    "confidence",
    "assembled_at"
  ],
  "properties": {
    "contract": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/contractRef"
    },
    "assembly_id": {
      "type": "string",
      "pattern": "^KAS-[0-9]{4}-[0-9]{6}$"
    },
    "request_id": {
      "type": "string"
    },
    "knowledge_set_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "selected_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "knowledge_id",
          "version",
          "selection_reason",
          "required",
          "confidence"
        ],
        "properties": {
          "knowledge_id": {
            "type": "string",
            "pattern": "^KN-[A-Z]{3}-[0-9]{3}$"
          },
          "version": {
            "type": "string"
          },
          "selection_reason": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "confidence": {
            "$ref": "../../../schemas/common/common.schema.json#/$defs/confidence"
          },
          "applicable_sections": {
            "$ref": "../../../schemas/common/common.schema.json#/$defs/stringArray"
          }
        },
        "additionalProperties": false
      }
    },
    "rejected_items": {
      "type": "array"
    },
    "required_missing_items": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/stringArray"
    },
    "conflict_records": {
      "type": "array"
    },
    "coverage": {
      "type": "string",
      "enum": [
        "complete",
        "sufficient",
        "partial",
        "insufficient",
        "blocked"
      ]
    },
    "confidence": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/confidence"
    },
    "assembled_at": {
      "$ref": "../../../schemas/common/common.schema.json#/$defs/isoDateTime"
    }
  },
  "additionalProperties": false
}