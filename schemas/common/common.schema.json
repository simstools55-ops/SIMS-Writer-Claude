{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/common/common.schema.json",
  "$defs": {
    "contractRef": {
      "type": "object",
      "required": [
        "id",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CT-[A-Z]{3}-[0-9]{3}$"
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "isoDateTime": {
      "type": "string",
      "format": "date-time"
    },
    "url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "verified",
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "validationStatus": {
      "type": "string",
      "enum": [
        "valid",
        "valid_with_warnings",
        "incomplete",
        "invalid",
        "unsupported",
        "manual_review_required"
      ]
    },
    "issueSeverity": {
      "type": "string",
      "enum": [
        "blocker",
        "critical",
        "major",
        "minor",
        "advisory"
      ]
    },
    "publishDecision": {
      "type": "string",
      "enum": [
        "publish_ready",
        "publish_ready_with_advisory",
        "conditional_approval",
        "manual_review_required",
        "revision_required",
        "rejected"
      ]
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "metricBlock": {
      "type": "object",
      "properties": {
        "clicks": {
          "type": "integer",
          "minimum": 0
        },
        "impressions": {
          "type": "integer",
          "minimum": 0
        },
        "ctr": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "average_position": {
          "type": "number",
          "minimum": 0
        },
        "measurement_period": {
          "type": "object",
          "required": [
            "from",
            "to"
          ],
          "properties": {
            "from": {
              "type": "string",
              "format": "date"
            },
            "to": {
              "type": "string",
              "format": "date"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}