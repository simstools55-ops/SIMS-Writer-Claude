{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/SIMS_FEEDBACK_V2.schema.json",
  "title": "SIMS Feedback V2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "version",
    "article_id",
    "article_url",
    "completed_at",
    "diagnosis",
    "primary_intent",
    "changes",
    "new_values",
    "improvement_type",
    "confidence",
    "effect_confidence",
    "expected_effect",
    "next_action",
    "summary",
    "warnings",
    "estimated_minutes",
    "recommended_review_days",
    "preservation_score",
    "protected_elements",
    "change_budget_percent",
    "rewrite_level",
    "rewrite_scope",
    "risk",
    "validation"
  ],
  "properties": {
    "format": {
      "const": "SIMS_FEEDBACK_V2"
    },
    "version": {
      "const": "2.0"
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "article_url": {
      "type": "string",
      "format": "uri"
    },
    "completed_at": {
      "type": "string",
      "format": "date"
    },
    "diagnosis": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "POSITION_OPPORTUNITY",
          "LOW_SAMPLE",
          "CTR_OPPORTUNITY",
          "CONTENT_GAP",
          "INTENT_MISMATCH",
          "STRONG_CURRENT_PERFORMANCE",
          "STABLE",
          "INPUT_INCOMPLETE",
          "UNKNOWN",
          "OTHER"
        ]
      }
    },
    "primary_intent": {
      "type": "string",
      "minLength": 1
    },
    "secondary_intent": {
      "type": [
        "string",
        "null"
      ]
    },
    "changes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "article_title",
        "seo_title",
        "description",
        "introduction",
        "headings",
        "faq",
        "internal_links",
        "body",
        "images"
      ],
      "properties": {
        "article_title": {
          "type": "boolean"
        },
        "seo_title": {
          "type": "boolean"
        },
        "description": {
          "type": "boolean"
        },
        "introduction": {
          "type": "boolean"
        },
        "headings": {
          "type": "boolean"
        },
        "faq": {
          "type": "boolean"
        },
        "internal_links": {
          "type": "boolean"
        },
        "body": {
          "type": "boolean"
        },
        "images": {
          "type": "boolean"
        }
      }
    },
    "new_values": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "article_title",
        "seo_title",
        "description",
        "main_query"
      ],
      "properties": {
        "article_title": {
          "type": "string"
        },
        "seo_title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "main_query": {
          "type": "string"
        }
      }
    },
    "improvement_type": {
      "enum": [
        "minor",
        "normal",
        "major"
      ]
    },
    "confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "effect_confidence": {
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "expected_effect": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ctr",
        "clicks"
      ],
      "properties": {
        "ctr": {
          "type": "string"
        },
        "clicks": {
          "type": "string"
        }
      }
    },
    "next_action": {
      "enum": [
        "monitor",
        "remeasure",
        "rewrite",
        "none"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "estimated_minutes": {
      "type": "integer",
      "minimum": 0
    },
    "recommended_review_days": {
      "enum": [
        7,
        14,
        30
      ]
    },
    "preservation_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "protected_elements": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "change_budget_percent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "rewrite_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4"
      ]
    },
    "rewrite_scope": {
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3",
        "S4",
        "S5"
      ]
    },
    "risk": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result",
        "title_length",
        "intent_alignment",
        "change_budget",
        "protected_content",
        "failed_rules",
        "warning_rules"
      ],
      "properties": {
        "result": {
          "enum": [
            "PASS",
            "PASS_WITH_WARNING",
            "FAIL",
            "UNVERIFIABLE"
          ]
        },
        "title_length": {
          "enum": [
            "PASS",
            "WARNING",
            "FAIL",
            "NOT_APPLICABLE"
          ]
        },
        "intent_alignment": {
          "enum": [
            "PASS",
            "WARNING",
            "FAIL",
            "UNVERIFIABLE"
          ]
        },
        "change_budget": {
          "enum": [
            "PASS",
            "WARNING",
            "FAIL"
          ]
        },
        "protected_content": {
          "enum": [
            "PASS",
            "WARNING",
            "FAIL",
            "UNVERIFIABLE"
          ]
        },
        "failed_rules": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "warning_rules": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "internal_link_evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "added",
        "held",
        "rejected"
      ],
      "properties": {
        "added": {
          "type": "integer",
          "minimum": 0
        },
        "held": {
          "type": "integer",
          "minimum": 0
        },
        "rejected": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
