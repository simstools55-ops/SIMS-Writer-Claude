{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIMS_FEEDBACK_V1",
  "type": "object",
  "required": [
    "version",
    "article_id",
    "url",
    "decision",
    "summary",
    "changes"
  ],
  "properties": {
    "version": {
      "const": "1.2"
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNING",
        "REVIEW_REQUIRED",
        "BLOCK"
      ]
    },
    "summary": {
      "type": "string"
    },
    "diagnosis": {
      "type": "string"
    },
    "preservation_score": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "change_budget_percent": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0,
      "maximum": 100
    },
    "rewrite_level": {
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5",
        null
      ]
    },
    "rewrite_scope": {
      "enum": [
        "S0",
        "S1",
        "S2",
        "S3",
        "S4",
        "S5",
        null
      ]
    },
    "risk": {
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        null
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "protected_elements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target",
          "before",
          "after",
          "reason"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "before": {
            "type": "string"
          },
          "after": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}