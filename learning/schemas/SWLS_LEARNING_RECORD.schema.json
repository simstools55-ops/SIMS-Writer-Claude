{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/SWLS_LEARNING_RECORD-v1.0.schema.json",
  "title": "SWLS Learning Record v1.0 Beta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "version",
    "article_id",
    "article_url",
    "recorded_at",
    "batch_key",
    "diagnosis",
    "decision",
    "confidence",
    "effect_confidence",
    "change_targets",
    "validation_rules",
    "uncertainties",
    "learning_candidates"
  ],
  "properties": {
    "format": {
      "const": "SWLS_LEARNING_RECORD"
    },
    "version": {
      "const": "1.0-beta"
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "article_url": {
      "type": "string",
      "minLength": 1
    },
    "recorded_at": {
      "type": "string"
    },
    "batch_key": {
      "type": "string",
      "pattern": "^BATCH-[0-9]{3,}$"
    },
    "diagnosis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "enum": [
        "PASS",
        "PASS_WITH_WARNING",
        "REVIEW_REQUIRED",
        "BLOCK"
      ]
    },
    "confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "effect_confidence": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "change_targets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "validation_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "failed",
        "warnings"
      ],
      "properties": {
        "failed": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "uncertainties": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preserved_elements": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "learning_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "proposal",
          "evidence",
          "confidence"
        ],
        "properties": {
          "target": {
            "enum": [
              "PROJECT_INSTRUCTIONS",
              "RUNTIME",
              "VALIDATION",
              "KNOWLEDGE",
              "CONTRACT",
              "PATTERN_LIBRARY",
              "TEST_COVERAGE"
            ]
          },
          "proposal": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "confidence": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    },
    "measurement_due_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 180
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
