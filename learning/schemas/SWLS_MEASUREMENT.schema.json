{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sims-writer.local/schemas/SWLS_MEASUREMENT-v1.0.schema.json",
  "title": "SWLS Measurement v1.0 Beta",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "format",
    "version",
    "article_id",
    "measured_at",
    "days_after",
    "before",
    "after"
  ],
  "properties": {
    "format": {
      "const": "SWLS_MEASUREMENT"
    },
    "version": {
      "const": "1.0-beta"
    },
    "article_id": {
      "type": "string",
      "minLength": 1
    },
    "measured_at": {
      "type": "string"
    },
    "days_after": {
      "type": "integer",
      "minimum": 1
    },
    "before": {
      "$ref": "#/$defs/metrics"
    },
    "after": {
      "$ref": "#/$defs/metrics"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "clicks",
        "impressions",
        "ctr_percent",
        "position"
      ],
      "properties": {
        "clicks": {
          "type": "number",
          "minimum": 0
        },
        "impressions": {
          "type": "number",
          "minimum": 0
        },
        "ctr_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "position": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
